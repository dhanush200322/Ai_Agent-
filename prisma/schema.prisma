generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                        String                      @id @default(uuid()) @db.Uuid
  name                      String
  slug                      String                      @unique
  logoUrl                   String?
  website                   String?
  industry                  String?
  country                   String?
  timezone                  String?
  status                    OrganizationStatus          @default(ACTIVE)
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  deletedAt                 DateTime?
  aiProviders               AIProvider[]
  agents                    Agent[]
  agentExecutions           AgentExecution[]
  agentPolicies             AgentPolicy[]
  agentSessions             AgentSession[]
  agentTeams                AgentTeam[]
  alerts                    Alert[]
  alertHistories            AlertHistory[]
  alertNotifications        AlertNotification[]
  alertRules                AlertRule[]
  apiKeys                   ApiKey[]
  apiRequestLogs            ApiRequestLog[]
  audioGenerationExecutions AudioGenerationExecution[]
  auditLogs                 AuditLog[]
  securityPolicies          AuthenticationPolicy?
  billingEvents             BillingEvent[]
  completionLogs            CompletionLog[]
  connectors                Connector[]
  connectorAudits           ConnectorAudit[]
  connectorConfigurations   ConnectorConfiguration[]
  connectorCredentials      ConnectorCredential[]
  connectorHealths          ConnectorHealth[]
  connectorMetrics          ConnectorMetrics[]
  connectorPermissions      ConnectorPermission[]
  connectorPolicies         ConnectorPolicy[]
  connectorQuotas           ConnectorQuota[]
  connectorUsages           ConnectorUsage[]
  conversations             Conversation[]
  costAnalytics             CostAnalytics[]
  creditWallet              CreditWallet?
  dashboardSnapshots        DashboardSnapshot[]
  deadLetterJobs            DeadLetterJob[]
  DeveloperOAuthApplication DeveloperOAuthApplication[]
  embeddingExecutions       EmbeddingExecution[]
  errorLogs                 ErrorLog[]
  externalAccounts          ExternalAccount[]
  externalEvents            ExternalEvent[]
  imageGenerationExecutions ImageGenerationExecution[]
  integrationInstances      IntegrationInstance[]
  invitations               Invitation[]
  invoices                  Invoice[]
  jobExecutions             JobExecution[]
  jobs                      JobQueue[]
  knowledgeBases            KnowledgeBase[]
  knowledgeDocuments        KnowledgeDocument[]
  modelCosts                ModelCost[]
  modelFeedback             ModelFeedback[]
  modelQuotas               ModelQuota[]
  modelUsages               ModelUsage[]
  notifications             Notification[]
  notificationAnalytics     NotificationAnalytics[]
  notificationAudits        NotificationAudit[]
  notificationPreferences   NotificationPreference[]
  notificationProviders     NotificationProvider[]
  notificationTemplates     NotificationTemplate[]
  notificationWebhooks      NotificationWebhook[]
  oauthConnections          OAuthConnection[]
  orgEntitlements           OrganizationEntitlement[]
  subscription              OrganizationSubscription?
  plugins                   Plugin[]
  pluginEvents              PluginEvent[]
  pluginInstallations       PluginInstallation[]
  pluginLogs                PluginLog[]
  pluginPermissions         PluginPermission[]
  pluginSchedules           PluginSchedule[]
  pluginWebhooks            PluginWebhook[]
  promptExecutions          PromptExecution[]
  promptLibraries           PromptLibrary[]
  queueMetrics              QueueMetric[]
  queuePolicies             QueuePolicy[]
  rateLimitPolicies         RateLimitPolicy[]
  roles                     Role[]
  scheduledJobs             ScheduledJob[]
  secretLeases              SecretLease[]
  secretShares              SecretShare[]
  streamingSessions         StreamingSession[]
  systemMetrics             SystemMetric[]
  tokenAnalytics            TokenAnalytics[]
  tokenUsages               TokenUsage[]
  tools                     Tool[]
  traces                    Trace[]
  usageAnalytics            UsageAnalytics[]
  usageEvents               UsageEvent[]
  usageQuota                UsageQuota?
  usageSummaries            UsageSummary[]
  users                     User[]
  vaultSecrets              VaultSecret[]
  webhookSubscriptions      WebhookSubscription[]
  workflows                 Workflow[]
  workflowExecutions        WorkflowExecution[]
  workflowTemplates         WorkflowTemplate[]

  @@index([status])
}

model User {
  id                         String                    @id @default(uuid()) @db.Uuid
  firstName                  String
  lastName                   String
  email                      String                    @unique
  passwordHash               String
  avatar                     String?
  phone                      String?
  emailVerified              Boolean                   @default(false)
  emailVerifiedAt            DateTime?
  lastLogin                  DateTime?
  lastLoginIp                String?
  isOwner                    Boolean                   @default(false)
  status                     UserStatus                @default(ACTIVE)
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  deletedAt                  DateTime?
  organizationId             String                    @db.Uuid
  roleId                     String                    @db.Uuid
  createdAgents              Agent[]                   @relation("CreatedAgents")
  agentSessions              AgentSession[]
  createdAgentTeams          AgentTeam[]               @relation("CreatedAgentTeams")
  auditLogs                  AuditLog[]                @relation("UserAuditLogs")
  conversations              Conversation[]
  Developer                  Developer?
  identityProviders          IdentityProviderAccount[]
  sentInvitations            Invitation[]              @relation("SentInvitations")
  createdKnowledgeBases      KnowledgeBase[]           @relation("CreatedKnowledgeBases")
  uploadedKnowledgeDocuments KnowledgeDocument[]       @relation("UploadedKnowledgeDocuments")
  loginHistory               LoginHistory[]
  notifications              Notification[]
  notificationPreferences    NotificationPreference[]
  installedPlugins           PluginInstallation[]      @relation("InstalledPlugins")
  grantedPluginPermissions   PluginPermission[]        @relation("GrantedPluginPermissions")
  rateLimitPolicies          RateLimitPolicy[]
  recoveryCodes              RecoveryCode[]
  sessionAudits              SessionAudit[]
  devices                    TrustedDevice[]
  organization               Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role                       Role                      @relation(fields: [roleId], references: [id])
  mfas                       UserMFA[]
  sessions                   UserSession[]
  createdWorkflows           Workflow[]                @relation("CreatedWorkflows")
  approvedWorkflows          WorkflowApproval[]        @relation("ApprovedWorkflows")

  @@index([organizationId])
  @@index([roleId])
  @@index([status])
}

model Role {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  organizationId String       @db.Uuid
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  invitations    Invitation[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]
  permissions    Permission[] @relation("RolePermissions")

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  category    String
  resource    String
  action      String
  createdAt   DateTime @default(now())
  roles       Role[]   @relation("RolePermissions")

  @@index([resource, action])
}

model Agent {
  id                 String                     @id @default(uuid()) @db.Uuid
  name               String
  slug               String
  description        String?
  avatar             String?
  model              String
  systemPrompt       String?
  temperature        Float                      @default(0.7)
  topP               Float                      @default(1.0)
  maxTokens          Int                        @default(2048)
  visibility         AgentVisibility            @default(PRIVATE)
  status             AgentStatus                @default(ACTIVE)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  deletedAt          DateTime?
  organizationId     String                     @db.Uuid
  createdById        String                     @db.Uuid
  maxExecutionTimeMs Int                        @default(30000)
  maxParallelTools   Int                        @default(3)
  maxPlannerDepth    Int                        @default(5)
  maxToolExecutions  Int                        @default(10)
  plannerEnabled     Boolean                    @default(true)
  plannerModel       String?
  plannerTemperature Float                      @default(0.7)
  toolCallingEnabled Boolean                    @default(true)
  themeConfig        Json?
  createdBy          User                       @relation("CreatedAgents", fields: [createdById], references: [id])
  organization       Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  capabilities       AgentCapability[]
  contexts           AgentContext[]
  delegationsFrom    AgentDelegation[]          @relation("DelegatedFrom")
  delegationsTo      AgentDelegation[]          @relation("DelegatedTo")
  events             AgentEvent[]
  executions         AgentExecution[]
  heartbeat          AgentHeartbeat?
  knowledgeBases     AgentKnowledgeBase[]
  receivedMessages   AgentMessage[]             @relation("ReceivedMessages")
  sentMessages       AgentMessage[]             @relation("SentMessages")
  runtimeConfig      AgentRuntimeConfiguration?
  sessions           AgentSession[]
  state              AgentState?
  assignedTasks      AgentTask[]                @relation("AssignedTasks")
  teamMemberships    AgentTeamMember[]
  agentTools         AgentTool[]
  conversations      Conversation[]
  toolExecutions     ToolExecution[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([createdById])
  @@index([status])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

model Invitation {
  id             String           @id @default(uuid()) @db.Uuid
  email          String
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organizationId String           @db.Uuid
  roleId         String           @db.Uuid
  inviterId      String           @db.Uuid
  inviter        User             @relation("SentInvitations", fields: [inviterId], references: [id])
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role             @relation(fields: [roleId], references: [id])

  @@index([organizationId])
  @@index([token])
  @@index([email])
}

model KnowledgeBase {
  id             String               @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?
  organizationId String               @db.Uuid
  createdById    String               @db.Uuid
  agents         AgentKnowledgeBase[]
  createdBy      User                 @relation("CreatedKnowledgeBases", fields: [createdById], references: [id])
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents      KnowledgeDocument[]

  @@index([organizationId])
  @@index([createdById])
  @@index([organizationId, deletedAt])
}

model AgentKnowledgeBase {
  id              String        @id @default(uuid()) @db.Uuid
  agentId         String        @db.Uuid
  knowledgeBaseId String        @db.Uuid
  createdAt       DateTime      @default(now())
  agent           Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@unique([agentId, knowledgeBaseId])
  @@index([agentId])
  @@index([knowledgeBaseId])
}

model KnowledgeDocument {
  id              String        @id @default(uuid()) @db.Uuid
  knowledgeBaseId String        @db.Uuid
  organizationId  String        @db.Uuid
  uploadedById    String        @db.Uuid
  originalName    String
  fileName        String?
  mimeType        String?
  extension       String?
  size            Int?
  storagePath     String?
  status          String        @default("PENDING")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?
  chunkCount      Int?
  embeddingModel  String?
  errorMessage    String?
  processedAt     DateTime?
  processingTime  Int?
  metadata        String?
  sourceType      String        @default("DOCUMENT")
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy      User          @relation("UploadedKnowledgeDocuments", fields: [uploadedById], references: [id])

  @@index([knowledgeBaseId])
  @@index([organizationId])
  @@index([uploadedById])
  @@index([organizationId, deletedAt])
  @@index([knowledgeBaseId, deletedAt])
}

model Conversation {
  id             String                @id @default(uuid()) @db.Uuid
  sessionId      String?               @db.VarChar(255)
  title          String?               @db.VarChar(255)
  summary        String?
  status         ConversationStatus    @default(ACTIVE)
  organizationId String                @db.Uuid
  agentId        String                @db.Uuid
  userId         String                @db.Uuid
  lastMessageAt  DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  deletedAt      DateTime?
  agent          Agent                 @relation(fields: [agentId], references: [id], onDelete: Cascade)
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  memories       ConversationMemory[]
  messages       ConversationMessage[]
  toolExecutions ToolExecution[]

  @@index([organizationId])
  @@index([agentId])
  @@index([userId])
  @@index([sessionId])
  @@index([status])
}

model ConversationMessage {
  id               String       @id @default(uuid()) @db.Uuid
  conversationId   String       @db.Uuid
  role             MessageRole
  content          String
  model            String?
  temperature      Float?
  latency          Int?
  finishReason     String?
  streaming        Boolean      @default(false)
  tokens           Int?
  promptTokens     Int?
  completionTokens Int?
  createdAt        DateTime     @default(now())
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model ConversationMemory {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  organizationId String       @db.Uuid
  agentId        String       @db.Uuid
  messageId      String?      @db.Uuid
  content        String
  summary        String?
  embeddingModel String
  vectorId       String       @unique
  memoryType     MemoryType   @default(SHORT_TERM)
  importance     Float        @default(0.0)
  score          Float?
  retrievalCount Int          @default(0)
  lastAccessed   DateTime?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([organizationId])
  @@index([agentId])
  @@index([memoryType])
}

model Tool {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  name           String
  displayName    String
  description    String
  category       String
  parameters     String?
  enabled        Boolean          @default(true)
  version        String           @default("1.0.0")
  timeout        Int              @default(30000)
  retryCount     Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  agentTools     AgentTool[]
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  credentials    ToolCredential[]
  executions     ToolExecution[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([category])
}

model ToolCredential {
  id               String   @id @default(uuid()) @db.Uuid
  toolId           String   @db.Uuid
  organizationId   String   @db.Uuid
  encryptedSecrets String
  createdAt        DateTime @default(now())
  tool             Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId])
  @@index([organizationId])
}

model AgentTool {
  id            String   @id @default(uuid()) @db.Uuid
  agentId       String   @db.Uuid
  toolId        String   @db.Uuid
  enabled       Boolean  @default(true)
  priority      Int      @default(0)
  configuration String?
  createdAt     DateTime @default(now())
  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tool          Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([agentId, toolId])
  @@index([agentId])
  @@index([toolId])
}

model ToolExecution {
  id             String              @id @default(uuid()) @db.Uuid
  conversationId String              @db.Uuid
  agentId        String              @db.Uuid
  toolId         String              @db.Uuid
  status         ToolExecutionStatus @default(PENDING)
  input          String
  output         String?
  error          String?
  duration       Int?
  startedAt      DateTime            @default(now())
  finishedAt     DateTime?
  agent          Agent               @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conversation   Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tool           Tool                @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([agentId])
  @@index([toolId])
  @@index([status])
}

model Workflow {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @db.Uuid
  createdById    String              @db.Uuid
  name           String
  slug           String
  description    String?
  status         WorkflowStatus      @default(DRAFT)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?
  createdBy      User                @relation("CreatedWorkflows", fields: [createdById], references: [id])
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executions     WorkflowExecution[]
  schedules      WorkflowSchedule[]
  templates      WorkflowTemplate[]
  triggers       WorkflowTrigger[]
  variables      WorkflowVariable[]
  versions       WorkflowVersion[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([createdById])
}

model WorkflowVersion {
  id                 String                @id @default(uuid()) @db.Uuid
  workflowId         String                @db.Uuid
  version            Int
  nodes              String
  connections        String
  metadata           String
  published          Boolean               @default(false)
  createdAt          DateTime              @default(now())
  status             WorkflowVersionStatus @default(DRAFT)
  versionConnections WorkflowConnection[]
  executions         WorkflowExecution[]
  versionNodes       WorkflowNode[]
  snapshots          WorkflowSnapshot[]
  workflow           Workflow              @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, version])
  @@index([workflowId])
}

model WorkflowNode {
  id                String               @id @default(uuid()) @db.Uuid
  nodeId            String
  workflowVersionId String               @db.Uuid
  type              String
  label             String
  config            String
  metadata          String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  sourceConnections WorkflowConnection[] @relation("SourceNode")
  targetConnections WorkflowConnection[] @relation("TargetNode")
  workflowVersion   WorkflowVersion      @relation(fields: [workflowVersionId], references: [id], onDelete: Cascade)

  @@unique([workflowVersionId, nodeId])
  @@index([workflowVersionId])
}

model WorkflowConnection {
  id                String          @id @default(uuid()) @db.Uuid
  workflowVersionId String          @db.Uuid
  sourceNodeId      String
  targetNodeId      String
  sourceHandle      String?
  targetHandle      String?
  condition         String?
  createdAt         DateTime        @default(now())
  workflowVersion   WorkflowVersion @relation(fields: [workflowVersionId], references: [id], onDelete: Cascade)
  sourceNode        WorkflowNode    @relation("SourceNode", fields: [workflowVersionId, sourceNodeId], references: [workflowVersionId, nodeId], onDelete: Cascade)
  targetNode        WorkflowNode    @relation("TargetNode", fields: [workflowVersionId, targetNodeId], references: [workflowVersionId, nodeId], onDelete: Cascade)

  @@index([workflowVersionId])
}

model WorkflowExecution {
  id                String                  @id @default(uuid()) @db.Uuid
  workflowVersionId String                  @db.Uuid
  organizationId    String                  @db.Uuid
  status            WorkflowExecutionStatus @default(PENDING)
  state             String?
  startedAt         DateTime                @default(now())
  finishedAt        DateTime?
  error             String?
  workflowId        String?                 @db.Uuid
  approvals         WorkflowApproval[]
  organization      Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow          Workflow?               @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowVersion   WorkflowVersion         @relation(fields: [workflowVersionId], references: [id], onDelete: Cascade)
  logs              WorkflowExecutionLog[]
  steps             WorkflowExecutionStep[]
  snapshots         WorkflowSnapshot[]

  @@index([workflowVersionId])
  @@index([organizationId])
  @@index([status])
}

model WorkflowExecutionStep {
  id          String              @id @default(uuid()) @db.Uuid
  executionId String              @db.Uuid
  nodeId      String
  nodeType    String
  status      NodeExecutionStatus @default(PENDING)
  input       String?
  output      String?
  error       String?
  duration    Int?
  startedAt   DateTime            @default(now())
  finishedAt  DateTime?
  execution   WorkflowExecution   @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([nodeId])
}

model WorkflowVariable {
  id         String   @id @default(uuid()) @db.Uuid
  workflowId String   @db.Uuid
  key        String
  value      String
  isSecret   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, key])
}

model WorkflowTrigger {
  id         String   @id @default(uuid()) @db.Uuid
  workflowId String   @db.Uuid
  type       String
  config     String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([type])
}

model WorkflowSchedule {
  id         String    @id @default(uuid()) @db.Uuid
  workflowId String    @db.Uuid
  cron       String
  timezone   String    @default("UTC")
  enabled    Boolean   @default(true)
  lastRunAt  DateTime?
  nextRunAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  workflow   Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model WorkflowApproval {
  id           String                 @id @default(uuid()) @db.Uuid
  executionId  String                 @db.Uuid
  nodeId       String
  requestedAt  DateTime               @default(now())
  approvedAt   DateTime?
  approvedById String?                @db.Uuid
  status       WorkflowApprovalStatus @default(PENDING)
  approvedBy   User?                  @relation("ApprovedWorkflows", fields: [approvedById], references: [id])
  execution    WorkflowExecution      @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([status])
}

model WorkflowExecutionLog {
  id          String              @id @default(uuid()) @db.Uuid
  executionId String              @db.Uuid
  nodeId      String
  nodeType    String
  status      NodeExecutionStatus @default(PENDING)
  input       String?
  output      String?
  error       String?
  duration    Int?
  startedAt   DateTime            @default(now())
  finishedAt  DateTime?
  execution   WorkflowExecution   @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([nodeId])
}

model WorkflowSnapshot {
  id                String            @id @default(uuid()) @db.Uuid
  executionId       String            @db.Uuid
  workflowVersionId String            @db.Uuid
  nodeId            String
  state             String
  createdAt         DateTime          @default(now())
  execution         WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  workflowVersion   WorkflowVersion   @relation(fields: [workflowVersionId], references: [id], onDelete: Cascade)

  @@index([executionId])
}

model WorkflowTemplate {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String?       @db.Uuid
  name           String
  description    String?
  nodes          String
  connections    String
  metadata       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  workflowId     String?       @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow       Workflow?     @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model AgentTeam {
  id                String            @id @default(uuid()) @db.Uuid
  organizationId    String            @db.Uuid
  name              String
  description       String?
  consensusStrategy ConsensusStrategy @default(STRICT)
  createdById       String            @db.Uuid
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  tasks             AgentTask[]
  createdBy         User              @relation("CreatedAgentTeams", fields: [createdById], references: [id])
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members           AgentTeamMember[]
  sharedMemories    SharedMemory[]

  @@index([organizationId])
}

model AgentTeamMember {
  id             String    @id @default(uuid()) @db.Uuid
  teamId         String    @db.Uuid
  agentId        String    @db.Uuid
  role           TeamRole  @default(WORKER)
  customRoleName String?
  createdAt      DateTime  @default(now())
  agent          Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  team           AgentTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, agentId])
  @@index([teamId])
  @@index([agentId])
}

model AgentCapability {
  id        String   @id @default(uuid()) @db.Uuid
  agentId   String   @db.Uuid
  name      String
  priority  Int      @default(0)
  version   String   @default("1.0")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, name])
  @@index([agentId])
  @@index([name])
}

model AgentTask {
  id              String            @id @default(uuid()) @db.Uuid
  teamId          String            @db.Uuid
