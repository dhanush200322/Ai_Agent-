  createdAt      DateTime @default(now())
}

model DeveloperApplication {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  name        String
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
}

model ApiSubscription {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  planId         String   @db.Uuid
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
}

model ApiPlan {
  id        String @id @default(uuid()) @db.Uuid
  name      String
  price     Float
  currency  String @default("USD")
  quota     Int
  rateLimit Int
  features  Json
}

model ApiQuota {
  id             String   @id @default(uuid()) @db.Uuid
  subscriptionId String   @db.Uuid
  month          DateTime
  used           Int      @default(0)
  limit          Int
}

model ApiUsage {
  id         String   @id @default(uuid()) @db.Uuid
  apiKeyId   String   @db.Uuid
  endpoint   String
  method     String
  statusCode Int
  latencyMs  Int
  createdAt  DateTime @default(now())
}

model ApiAnalytics {
  id         String   @id @default(uuid()) @db.Uuid
  apiKeyId   String   @db.Uuid
  date       DateTime @db.Date
  requests   Int      @default(0)
  errors     Int      @default(0)
  latencyAvg Float    @default(0)
}

model ApiMetric {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  value     Float
  tags      Json
  timestamp DateTime @default(now())
}

model ApiRequest {
  id        String   @id @default(uuid()) @db.Uuid
  requestId String   @unique
  method    String
  path      String
  headers   Json?
  query     Json?
  body      Json?
  createdAt DateTime @default(now())
}

model ApiResponse {
  id         String   @id @default(uuid()) @db.Uuid
  requestId  String   @unique
  statusCode Int
  headers    Json?
  body       Json?
  latencyMs  Int
  createdAt  DateTime @default(now())
}

model ApiError {
  id        String   @id @default(uuid()) @db.Uuid
  requestId String   @unique
  errorCode String
  message   String
  stack     String?
