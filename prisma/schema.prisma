}

model ApiAudit {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  entityType String
  entityId   String
  actorId    String
  details    Json
  createdAt  DateTime @default(now())
}

model ApiWebhook {
  id            String   @id @default(uuid()) @db.Uuid
  applicationId String   @db.Uuid
