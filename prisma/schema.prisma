}

model TaxConfiguration {
  id          String   @id @default(uuid()) @db.Uuid
  countryCode String
  stateCode   String?
  taxType     String // GST, VAT, SALES_TAX
  rate        Decimal  @db.Decimal(5, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([countryCode, stateCode, taxType])
}

model BillingEvent {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  eventType      String // INVOICE_GENERATED, PAYMENT_FAILED
  payload        String   @db.Text // JSON
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([eventType])
}

model BillingWebhookEvent {
  id              String              @id @default(uuid()) @db.Uuid
  provider        PaymentProviderType
  providerEventId String              @unique
  eventType       String // invoice.payment_succeeded
  payload         String              @db.Text // JSON
  processed       Boolean             @default(false)
  error           String?             @db.Text
  createdAt       DateTime            @default(now())
  processedAt     DateTime?

  @@index([provider])
  @@index([processed])
}

// ==========================================
// Phase 6.14 Vault & Secrets Management
// ==========================================

enum VaultProviderType {
  DATABASE
  AWS_SECRETS_MANAGER
  AZURE_KEY_VAULT
  HASHICORP_VAULT
  GOOGLE_SECRET_MANAGER
}

enum SecretStatus {
  ACTIVE
  DISABLED
  DELETED
}

enum SecretCategory {
  AI_PROVIDER
  DATABASE
  PAYMENT
  SMTP
  OAUTH
  PLUGIN
  API_KEY
  JWT
  CUSTOM
}

enum RotationStrategy {
  MANUAL
  DAILY
  WEEKLY
  MONTHLY
  ON_DEMAND
  PROVIDER_MANAGED
}

model VaultSecret {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  name           String
  description    String?          @db.Text
  category       SecretCategory   @default(CUSTOM)
  provider       VaultProviderType @default(DATABASE)
  status         SecretStatus     @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions       VaultSecretVersion[]
  accessLogs     VaultAccessLog[]
  rotationPolicy SecretRotationPolicy?
  leases         SecretLease[]
  shares         SecretShare[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([status])
}

model VaultSecretVersion {
  id             String       @id @default(uuid()) @db.Uuid
  secretId       String       @db.Uuid
  version        Int
  encryptedValue String       @db.Text
  iv             String       @db.Text
  authTag        String       @db.Text
  keyVersion     Int          @default(1)
  createdAt      DateTime     @default(now())

  secret         VaultSecret  @relation(fields: [secretId], references: [id], onDelete: Cascade)

  @@unique([secretId, version])
}

model VaultAccessLog {
  id             String       @id @default(uuid()) @db.Uuid
  secretId       String       @db.Uuid
  action         String       // READ, UPDATE, ROTATE, DELETE, REVOKE
  actorId        String       @db.Uuid // UserId or System Component
  actorType      String       // USER, SYSTEM, PLUGIN
  ipAddress      String?
  userAgent      String?
  metadata       String?      @db.Text
  createdAt      DateTime     @default(now())

  secret         VaultSecret  @relation(fields: [secretId], references: [id], onDelete: Cascade)

  @@index([secretId])
  @@index([actorId])
  @@index([createdAt])
}

model SecretRotationPolicy {
  id             String           @id @default(uuid()) @db.Uuid
  secretId       String           @db.Uuid @unique
  strategy       RotationStrategy @default(MANUAL)
  cronExpression String?
  lastRotatedAt  DateTime?
  nextRotationAt DateTime?
  failureCount   Int              @default(0)
  autoRetry      Boolean          @default(true)
  metadata       String?          @db.Text // Configuration for provider rotation
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  secret         VaultSecret      @relation(fields: [secretId], references: [id], onDelete: Cascade)
}

model SecretLease {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  secretId       String       @db.Uuid
  actorId        String       @db.Uuid
  actorType      String       // PLUGIN, WORKFLOW
  expiresAt      DateTime
  isRevoked      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  secret         VaultSecret  @relation(fields: [secretId], references: [id], onDelete: Cascade)

  @@index([secretId])
  @@index([expiresAt])
}

model SecretShare {
  id               String       @id @default(uuid()) @db.Uuid
  secretId         String       @db.Uuid
  organizationId   String       @db.Uuid // Target organization/department (intra-org share for now)
  targetActorId    String?      @db.Uuid // Target user or role
  permission       String       // READ
  expiresAt        DateTime?
  createdAt        DateTime     @default(now())

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  secret           VaultSecret  @relation(fields: [secretId], references: [id], onDelete: Cascade)

  @@index([secretId])
  @@index([organizationId])
}

// ==========================================
// Phase 6.15: Enterprise Authentication & Zero Trust
// ==========================================

enum AuthenticationProvider {
  LOCAL
  GOOGLE
  MICROSOFT
  OKTA
  AUTH0
  GITHUB
  SAML
  LDAP
}

enum SessionStatus {
  ACTIVE
  INACTIVE
  REVOKED
  EXPIRED
  SUSPENDED
}

enum DeviceTrustLevel {
  TRUSTED
  UNTRUSTED
  SUSPICIOUS
  BLOCKED
}

enum MFAType {
  TOTP
  EMAIL
  SMS
  BACKUP_CODE
  SECURITY_KEY
}

enum LoginEventType {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  TOKEN_REFRESH
  MFA_CHALLENGE
  MFA_SUCCESS
  MFA_FAILED
  ACCOUNT_LOCKED
  PASSWORD_RESET
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model UserSession {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @db.Uuid
  deviceId       String?       @db.Uuid
  tokenFingerprint String      @unique
  ipAddress      String?
  userAgent      String?
  status         SessionStatus @default(ACTIVE)
  riskScore      Float         @default(0.0)
  lastActivityAt DateTime      @default(now())
  expiresAt      DateTime
  createdAt      DateTime      @default(now())

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  device         TrustedDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  refreshTokens  RefreshToken[]
  audits         SessionAudit[]

  @@index([userId])
  @@index([tokenFingerprint])
  @@index([status])
}

model RefreshToken {
  id             String        @id @default(uuid()) @db.Uuid
  sessionId      String        @db.Uuid
  tokenHash      String        @unique
  isRevoked      Boolean       @default(false)
  expiresAt      DateTime
  createdAt      DateTime      @default(now())
  replacedByToken String?      @db.Text

  session        UserSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([tokenHash])
}

model TrustedDevice {
  id             String           @id @default(uuid()) @db.Uuid
  userId         String           @db.Uuid
  deviceFingerprint String        @unique
  name           String?
  browser        String?
  os             String?
  trustLevel     DeviceTrustLevel @default(UNTRUSTED)
  lastIpAddress  String?
  lastUsedAt     DateTime         @default(now())
  createdAt      DateTime         @default(now())

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions       UserSession[]

  @@index([userId])
  @@index([deviceFingerprint])
}

model UserMFA {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @db.Uuid
  type           MFAType
  secret         String?       @db.Text // Encrypted in Vault
  isEnabled      Boolean       @default(false)
  isVerified     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model RecoveryCode {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @db.Uuid
  codeHash       String
  isUsed         Boolean       @default(false)
  usedAt         DateTime?
  createdAt      DateTime      @default(now())

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model IdentityProviderAccount {
  id             String                 @id @default(uuid()) @db.Uuid
  userId         String                 @db.Uuid
  provider       AuthenticationProvider
  providerUserId String
  email          String?
  accessToken    String?                @db.Text // Encrypted in Vault
  refreshToken   String?                @db.Text // Encrypted in Vault
  expiresAt      DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model LoginHistory {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @db.Uuid
  eventType      LoginEventType
  ipAddress      String?
  userAgent      String?
  location       String?        // Country/City based on IP
  riskScore      Float          @default(0.0)
  status         String         // SUCCESS, FAILED
  failureReason  String?        @db.Text
  createdAt      DateTime       @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model SessionAudit {
  id             String        @id @default(uuid()) @db.Uuid
  sessionId      String        @db.Uuid
  userId         String        @db.Uuid
  action         String
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime      @default(now())

  session        UserSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
}

// ==========================================
// Authentication Policy Engine Models
// ==========================================

model AuthenticationPolicy {
  id                   String        @id @default(uuid()) @db.Uuid
  organizationId       String        @db.Uuid @unique
  name                 String
  description          String?       @db.Text
  requireMfa           Boolean       @default(false)
  mfaEnforcementLevel  String        // OPTIONAL, REQUIRED_FOR_ADMINS, REQUIRED_FOR_ALL
  sessionTimeoutMins   Int           @default(1440) // 24 hours
  idleTimeoutMins      Int           @default(60)
  maxConcurrentSessions Int          @default(5)
  passwordMinLength    Int           @default(12)
  passwordRequireNum   Boolean       @default(true)
  passwordRequireSym   Boolean       @default(true)
  passwordRequireUpper Boolean       @default(true)
  passwordExpiryDays   Int           @default(90)
  passwordHistoryCount Int           @default(5)
  lockoutThreshold     Int           @default(5)
  lockoutDurationMins  Int           @default(30)
  enforceGeoRestriction Boolean       @default(false)
  enforceIpRestriction Boolean       @default(false)
  enforceWorkingHours  Boolean       @default(false)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  organization         Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ipRanges             IPRange[]
  geoRestrictions      GeoRestriction[]
  workingHours         WorkingHoursPolicy[]
}

model IPRange {
  id             String               @id @default(uuid()) @db.Uuid
  policyId       String               @db.Uuid
  type           String               // ALLOWLIST, BLOCKLIST
  cidr           String
  description    String?
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())

  policy         AuthenticationPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
  @@index([type])
}

model GeoRestriction {
  id             String               @id @default(uuid()) @db.Uuid
  policyId       String               @db.Uuid
  type           String               // ALLOWLIST, BLOCKLIST
  countryCode    String               // ISO 3166-1 alpha-2
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())

  policy         AuthenticationPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
}

model WorkingHoursPolicy {
  id             String               @id @default(uuid()) @db.Uuid
  policyId       String               @db.Uuid
  timezone       String               @default("UTC")
  monday         Boolean              @default(true)
  tuesday        Boolean              @default(true)
  wednesday      Boolean              @default(true)
  thursday       Boolean              @default(true)
  friday         Boolean              @default(true)
  saturday       Boolean              @default(false)
  sunday         Boolean              @default(false)
  startTime      String               // "09:00"
  endTime        String               // "17:00"
  createdAt      DateTime             @default(now())

  policy         AuthenticationPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
}

// ==========================================
// Phase 6.16 Notification, Communication & Messaging Models
// ==========================================

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  SLACK
  MS_TEAMS
  DISCORD
  WEBHOOK
  IN_APP
}

enum NotificationStatus {
  PENDING
  QUEUED
  PROCESSING
  SENT
  DELIVERED
  READ
  FAILED
  EXPIRED
  CANCELLED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationProviderType {
  SMTP
  SENDGRID
  SES
  TWILIO
  WHATSAPP
  SLACK
  DISCORD
  WEBHOOK
  FCM
  INAPP
}

enum NotificationEventType {
  LOGIN_ALERT
  MFA_ENABLED
  PASSWORD_RESET
  SUSPICIOUS_LOGIN
  INVOICE_GENERATED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  TRIAL_EXPIRY
  WORKFLOW_COMPLETED
  WORKFLOW_FAILED
  HUMAN_APPROVAL_REQUIRED
  PLUGIN_INSTALLED
  PLUGIN_UPDATED
  TASK_COMPLETED
  AGENT_FAILURE
  ESCALATION_REQUIRED
  HIGH_CPU
  HIGH_MEMORY
  QUEUE_FAILURE
  REDIS_FAILURE
  DATABASE_FAILURE
  CUSTOM
}

enum NotificationTemplateType {
  HTML
  TEXT
  MARKDOWN
  WHATSAPP
  SMS
  PUSH
  SLACK_BLOCKS
}

enum DeliveryStatus {
  SENT
  DELIVERED
  READ
  FAILED
  BOUNCED
  CLICKED
  OPENED
}

model Notification {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @db.Uuid
  userId         String?              @db.Uuid
  recipient      String
  channel        NotificationChannel
  priority       NotificationPriority @default(NORMAL)
  status         NotificationStatus   @default(PENDING)
  templateId     String?              @db.Uuid
  subject        String?
  body           String               @db.Text
  variables      String?              @db.Text // JSON string
  retryCount     Int                  @default(0)
  maxRetries     Int                  @default(3)
  providerId     String?              @db.Uuid
  errorMessage   String?              @db.Text
  scheduledAt    DateTime?
  sentAt         DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  isRead         Boolean              @default(false)
  readAt         DateTime?
  isArchived     Boolean              @default(false)
  archivedAt     DateTime?
  isDeleted      Boolean              @default(false)
  deletedAt      DateTime?

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  template       NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  provider       NotificationProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  deliveries     NotificationDelivery[]
  attachments    NotificationAttachment[]
  analytics      NotificationAnalytics[]
  schedule       NotificationSchedule?

  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([channel])
  @@index([createdAt])
}

model NotificationDelivery {
  id             String               @id @default(uuid()) @db.Uuid
  notificationId String               @db.Uuid
  providerId     String?              @db.Uuid
  status         NotificationStatus
  deliveryTime   DateTime?
  latency        Int?                 // ms
  retryCount     Int                  @default(0)
  error          String?              @db.Text
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  notification   Notification         @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  provider       NotificationProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([notificationId])
  @@index([status])
}

model NotificationTemplate {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @db.Uuid
  name           String
  slug           String
  type           NotificationTemplateType
  subject        String?
  content        String               @db.Text
  language       String               @default("en")
  version        String               @default("1.0.0")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  notifications  Notification[]

  @@unique([organizationId, slug, language])
  @@index([organizationId])
}

model NotificationPreference {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @db.Uuid
  userId         String?              @db.Uuid
  department     String?
  team           String?
  enabledChannels String?             @db.Text // JSON string list
  disabledChannels String?            @db.Text // JSON string list
  quietHoursStart String?             // "HH:MM"
  quietHoursEnd   String?             // "HH:MM"
  digestMode      Boolean              @default(false)
  digestFrequency String?             // "DAILY", "WEEKLY"
  priorityLevel   NotificationPriority @default(LOW)
  frequencyLimit  Int?                 // Max notifications per hour
  language        String               @default("en")
  timezone        String               @default("UTC")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
}

model NotificationProvider {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String?              @db.Uuid
  name           String
  type           NotificationProviderType
  config         String               @db.Text // Encrypted config JSON
  vaultSecretId  String?              @db.Uuid
  isActive       Boolean              @default(true)
  priority       Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization   Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  notifications  Notification[]
  deliveries     NotificationDelivery[]

  @@index([organizationId])
}

model NotificationQueue {
  id             String               @id @default(uuid()) @db.Uuid
  notificationId String?              @db.Uuid
  channel        NotificationChannel
  priority       NotificationPriority
  payload        String               @db.Text
  status         String               @default("PENDING")
  attempts       Int                  @default(0)
  maxAttempts    Int                  @default(3)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([status])
}

model NotificationAudit {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @db.Uuid
  userId         String?              @db.Uuid
  notificationId String?              @db.Uuid
  action         String
  ipAddress      String?
  userAgent      String?
  metadata       String?              @db.Text // JSON string
  createdAt      DateTime             @default(now())

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdAt])
}

model NotificationWebhook {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @db.Uuid
  url            String
  secret         String               // HMAC signing key
  events         String               // JSON array of event types
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model NotificationAttachment {
  id             String               @id @default(uuid()) @db.Uuid
  notificationId String               @db.Uuid
  fileName       String
  filePath       String
  fileSize       Int
  mimeType       String
  createdAt      DateTime             @default(now())

  notification   Notification         @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
}

model NotificationAnalytics {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @db.Uuid
  notificationId String?              @db.Uuid
  channel        NotificationChannel
  providerType   NotificationProviderType
  status         DeliveryStatus
  latency        Int?                 // ms
  isRead         Boolean              @default(false)
  readAt         DateTime?
  isClicked      Boolean              @default(false)
  clickedAt      DateTime?
  metadata       String?              @db.Text // JSON string
  timestamp      DateTime             @default(now())

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  notification   Notification?        @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([timestamp])
}

model NotificationSchedule {
  id             String               @id @default(uuid()) @db.Uuid
  notificationId String               @db.Uuid @unique
  cronExpression String?
  intervalMs     Int?
  runAt          DateTime?
  timezone       String               @default("UTC")
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  notification   Notification         @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([nextRunAt])
}

