# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/enterprise_ai_agent?schema=public"

# Redis Configuration
REDIS_URL="redis://localhost:6379"

# JWT Secret
JWT_ACCESS_SECRET="super-secret-access-key-replace-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-key-replace-in-production"
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
BCRYPT_ROUNDS=12
CLIENT_URL="http://localhost:3000"

# AI Service Keys
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
GROK_API_KEY=""
