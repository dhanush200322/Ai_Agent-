# JWT Secret
JWT_ACCESS_SECRET="super-secret-access-key-replace-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-key-replace-in-production"
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
BCRYPT_ROUNDS=12
CLIENT_URL="https://ai-agent-pohw.vercel.app"

# AI Service Keys
